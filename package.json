{
  "name": "file-date-decorator",
  "displayName": "File Date Decorator",
  "description": "Displays file dates (creation, modified, accessed) next to filenames in the Explorer sidebar",
  "version": "1.0.0",
  "publisher": "raymond",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "File Date Decorator",
      "properties": {
        "fileDateDecorator.dateFormat": {
          "type": "string",
          "default": "MM/DD/YYYY",
          "markdownDescription": "Date/time format string. Tokens: `YYYY` (4-digit year), `YY` (2-digit year), `MM` (month), `DD` (day), `hh` (hours 24h), `HH` (hours 12h), `mm` (minutes), `ss` (seconds), `A` (AM/PM). Examples: `MM/DD/YYYY`, `DD/MM/YY`, `DD/MM hh:mm:ss`, `YYYY-MM-DD hh:mm`"
        },
        "fileDateDecorator.dateSource": {
          "type": "string",
          "default": "modified",
          "enum": [
            "modified",
            "created",
            "accessed"
          ],
          "enumDescriptions": [
            "Last modified time (mtime) — what `ls -l` shows by default",
            "Creation / birth time (birthtime)",
            "Last accessed time (atime)"
          ],
          "description": "Which file timestamp to display."
        },
        "fileDateDecorator.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the file date decorator."
        },
        "fileDateDecorator.showOnFolders": {
          "type": "boolean",
          "default": false,
          "description": "Also show dates on folders (not just files)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fileDateExplorerContainer",
          "title": "File Dates",
          "icon": "$(calendar)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "fileDateExplorer",
          "name": "File Dates",
          "contextualTitle": "File Dates",
          "icon": "$(calendar)",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        { "command": "fileDateDecorator.newFile",          "when": "view == fileDateExplorer",              "group": "1_new@1" },
        { "command": "fileDateDecorator.newFolder",        "when": "view == fileDateExplorer",              "group": "1_new@2" },
        { "command": "fileDateDecorator.revealInFinder",   "when": "isMac && view == fileDateExplorer && viewItem != placeholder",    "group": "2_workspace@1" },
        { "command": "fileDateDecorator.revealInExplorer", "when": "isWindows && view == fileDateExplorer && viewItem != placeholder","group": "2_workspace@1" },
        { "command": "fileDateDecorator.revealInOS",       "when": "isLinux && view == fileDateExplorer && viewItem != placeholder",  "group": "2_workspace@1" },
        { "command": "fileDateDecorator.openInTerminal",   "when": "view == fileDateExplorer && viewItem != placeholder",             "group": "2_workspace@2" },
        { "command": "fileDateDecorator.findInFolder",     "when": "view == fileDateExplorer && viewItem == folder",                  "group": "3_search@1" },
        { "command": "fileDateDecorator.copyPath",         "when": "view == fileDateExplorer && viewItem != placeholder",             "group": "4_copy@1" },
        { "command": "fileDateDecorator.copyRelativePath", "when": "view == fileDateExplorer && viewItem != placeholder",             "group": "4_copy@2" },
        { "command": "fileDateDecorator.copyPath",         "when": "view == fileDateExplorer && viewItem == placeholder",             "group": "4_copy@1" },
        { "command": "fileDateDecorator.copyRelativePath", "when": "view == fileDateExplorer && viewItem == placeholder",             "group": "4_copy@2" },
        { "command": "fileDateDecorator.rename",              "when": "view == fileDateExplorer && viewItem != placeholder",                                                    "group": "5_edit@1" },
        { "command": "fileDateDecorator.delete",              "when": "view == fileDateExplorer && viewItem != placeholder",                                                    "group": "5_edit@2" },
        { "command": "fileDateDecorator.selectForCompare",    "when": "view == fileDateExplorer && viewItem == file",                                                           "group": "6_compare@1" },
        { "command": "fileDateDecorator.compareWithSelected", "when": "view == fileDateExplorer && viewItem == file && fileDateDecorator.compareFile != ''",                    "group": "6_compare@2" }
      ],
      "view/title": [
        {
          "command": "fileDateDecorator.refresh",
          "when": "view == fileDateExplorer",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.cycleDateSource.modified",
          "when": "view == fileDateExplorer && fileDateDecorator.dateSource == modified",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.cycleDateSource.created",
          "when": "view == fileDateExplorer && fileDateDecorator.dateSource == created",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.cycleDateSource.accessed",
          "when": "view == fileDateExplorer && fileDateDecorator.dateSource == accessed",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.toggleFolders.on",
          "when": "view == fileDateExplorer && fileDateDecorator.showOnFolders == true",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.toggleFolders.off",
          "when": "view == fileDateExplorer && fileDateDecorator.showOnFolders != true",
          "group": "navigation"
        },
        {
          "command": "fileDateDecorator.toggle",
          "when": "view == fileDateExplorer"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fileDateDecorator.rename",
        "key": "enter",
        "when": "focusedView == fileDateExplorer && viewItem != placeholder"
      },
      {
        "command": "fileDateDecorator.delete",
        "key": "cmd+backspace",
        "mac": "cmd+backspace",
        "when": "focusedView == fileDateExplorer && viewItem != placeholder"
      },
      {
        "command": "fileDateDecorator.copyPath",
        "key": "cmd+alt+c",
        "mac": "cmd+alt+c",
        "when": "focusedView == fileDateExplorer"
      },
      {
        "command": "fileDateDecorator.copyRelativePath",
        "key": "cmd+alt+shift+c",
        "mac": "cmd+alt+shift+c",
        "when": "focusedView == fileDateExplorer"
      },
      {
        "command": "fileDateDecorator.selectForCompare",
        "key": "cmd+shift+1",
        "mac": "cmd+shift+1",
        "when": "focusedView == fileDateExplorer"
      },
      {
        "command": "fileDateDecorator.compareWithSelected",
        "key": "cmd+shift+2",
        "mac": "cmd+shift+2",
        "when": "focusedView == fileDateExplorer"
      }
    ],
    "commands": [
      {
        "command": "fileDateDecorator.toggle",
        "title": "File Date Decorator: Toggle On/Off"
      },
      {
        "command": "fileDateDecorator.cycleDateSource.modified",
        "title": "File Date Decorator: modified",
        "icon": "$(calendar)"
      },
      {
        "command": "fileDateDecorator.cycleDateSource.created",
        "title": "File Date Decorator: created",
        "icon": "$(calendar)"
      },
      {
        "command": "fileDateDecorator.cycleDateSource.accessed",
        "title": "File Date Decorator: accessed",
        "icon": "$(calendar)"
      },
      {
        "command": "fileDateDecorator.refresh",
        "title": "File Date Decorator: Refresh Dates",
        "icon": "$(refresh)"
      },
      { "command": "fileDateDecorator.newFile",           "title": "New File..."                    },
      { "command": "fileDateDecorator.newFolder",         "title": "New Folder..."                  },
      { "command": "fileDateDecorator.revealInFinder",    "title": "Reveal in Finder"               },
      { "command": "fileDateDecorator.revealInExplorer",  "title": "Reveal in File Explorer"        },
      { "command": "fileDateDecorator.revealInOS",        "title": "Open Containing Folder"         },
      { "command": "fileDateDecorator.openInTerminal",    "title": "Open in Integrated Terminal"    },
      { "command": "fileDateDecorator.findInFolder",      "title": "Find in Folder..."              },
      { "command": "fileDateDecorator.copyPath",          "title": "Copy Path"                      },
      { "command": "fileDateDecorator.copyRelativePath",  "title": "Copy Relative Path"             },
      { "command": "fileDateDecorator.rename",              "title": "Rename..."                      },
      { "command": "fileDateDecorator.delete",            "title": "Delete"                         },
      { "command": "fileDateDecorator.selectForCompare",    "title": "Select for Compare"             },
      { "command": "fileDateDecorator.compareWithSelected", "title": "Compare with Selected"          },
      { "command": "fileDateDecorator.toggleFolders.on",  "title": "Hide Dates on Folders", "icon": "$(folder-active)" },
      { "command": "fileDateDecorator.toggleFolders.off", "title": "Show Dates on Folders", "icon": "$(folder)"        }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
